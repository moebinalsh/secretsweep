# ============================================================
# SecretSweep Configuration
# Copy to .env and fill in values
# Generate secrets: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================

# Database (PostgreSQL)
DATABASE_URL=postgres://secretsweep_app:YOUR_STRONG_PASSWORD@localhost:5432/secretsweep

# Auth Secrets (each MUST be unique 64-char hex strings)
SESSION_SECRET=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Encryption key for tokens at rest (MUST be 64 hex chars = 32 bytes)
ENCRYPTION_KEY=

# Server
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# CORS — your production domain (comma-separated for multiple)
ALLOWED_ORIGINS=https://app.yourdomain.com

# Super Admin — created via: node server/create-admin.js
# No credentials stored in env files
